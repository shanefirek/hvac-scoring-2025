      {
        "parameters": {
          "jsCode": "// Build campaign tracking records\nconst formatData = $('Format for Smartlead').item.json;\n\nconst records = formatData.lead_data.map(lead => ({\n  lead_id: lead.id,\n  smartlead_campaign_id: formatData.campaign_id,\n  campaign_name: formatData.campaign_name,\n  tier: formatData.tier,\n  status: 'PENDING'\n}));\n\nreturn [{ json: { records: records, count: records.length } }];"
        },
