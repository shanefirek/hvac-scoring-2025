      {
        "parameters": {
          "method": "PATCH",
          "url": "=https://rlmuovkdvbxzyylbiunj.supabase.co/rest/v1/leads?email=in.({{ $('Format for Smartlead').item.json.emails.join(',') }})",
          "authentication": "predefinedCredentialType",
          "nodeCredentialType": "supabaseApi",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ { \"in_smartlead\": true, \"last_smartlead_sync\": new Date().toISOString() } }}",
          "options": {}
        },
