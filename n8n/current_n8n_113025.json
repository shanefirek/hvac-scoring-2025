      {
        "parameters": {
          "jsCode": "// Parse Smartlead engagement event\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const body = item.json.body || item.json;\n\n  results.push({\n    json: {\n      smartlead_lead_id: body.sl_email_lead_id,\n      email: body.to_email,\n      campaign_id: parseInt(body.campaign_id || 0),\n      event_type: body.event_type,\n      sequence_number: parseInt(body.sequence_number || 0),\n      email_subject: body.subject,\n      email_stats_id: body.stats_id,\n      event_data: body\n    }\n  });\n}\n\nreturn results;"
        },
