      {
        "parameters": {
          "jsCode": "// Parse Clay webhook payload\n// Clay sends: clay_id, email, first_name, last_name, company, domain, linkedin_url, reviews_count, service_software, score, tier, messaging_strategy, phone, city, state, postal_code\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const body = item.json.body || item.json;\n  \n  results.push({\n    json: {\n      clay_id: body.clay_id || body.id,\n      email: body.email,\n      first_name: body.first_name || body.firstName,\n      last_name: body.last_name || body.lastName,\n      company: body.company || body.company_name,\n      domain: body.domain,\n      linkedin_url: body.linkedin_url || body.linkedinUrl,\n      reviews_count: parseInt(body.reviews_count || body.reviewsCount || body.reviews || 0),\n      service_software: body.service_software || body.serviceSoftware || null,\n      score: parseInt(body.score || 0),\n      tier: body.tier,\n      messaging_strategy: body.messaging_strategy || body.messagingStrategy,\n      score_breakdown: body.score_breakdown || body.scoreBreakdown || {},\n      // NEW: Location and contact fields\n      phone_number: body.phone || body.phone_number || null,\n      city: body.city || null,\n      state: body.state || null,\n      postal_code: body.postal_code || body.postalCode || body.zip || null,\n      clay_raw_data: body\n    }\n  });\n}\n\nreturn results;"
        },
        "id": "a4fbd772-50b8-4759-bbb6-7920c55e0514",
        "name": "Parse Clay Webhook Data",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1008,
          -208
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "=https://rlmuovkdvbxzyylbiunj.supabase.co/rest/v1/rpc/sync_lead_from_clay",
          "authentication": "predefinedCredentialType",
          "nodeCredentialType": "supabaseApi",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ {\n  \"p_clay_id\": $json.clay_id,\n  \"p_email\": $json.email,\n  \"p_first_name\": $json.first_name,\n  \"p_last_name\": $json.last_name,\n  \"p_company\": $json.company,\n  \"p_domain\": $json.domain,\n  \"p_linkedin_url\": $json.linkedin_url,\n  \"p_reviews_count\": $json.reviews_count,\n  \"p_service_software\": $json.service_software,\n  \"p_score\": $json.score,\n  \"p_tier\": $json.tier,\n  \"p_messaging_strategy\": $json.messaging_strategy,\n  \"p_score_breakdown\": $json.score_breakdown,\n  \"p_clay_data\": $json.clay_raw_data,\n  \"p_phone_number\": $json.phone_number,\n  \"p_city\": $json.city,\n  \"p_state\": $json.state,\n  \"p_postal_code\": $json.postal_code\n} }}",
          "options": {
