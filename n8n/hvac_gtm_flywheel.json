              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"p_email\": $json.email,\n  \"p_campaign_id\": $json.campaign_id,\n  \"p_event_type\": $json.event_type,\n  \"p_sequence_number\": $json.sequence_number,\n  \"p_email_subject\": $json.email_subject,\n  \"p_email_stats_id\": $json.email_stats_id,\n  \"p_event_data\": $json.event_data\n} }}",
        "options": {}
      },
