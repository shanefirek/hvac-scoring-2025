        "mode": "runOnceForAllItems",
        "jsCode": "// Get current month for campaign filtering\nconst now = new Date();\nconst year = now.getFullYear();\nconst month = String(now.getMonth() + 1).padStart(2, '0');\n\nreturn [{\n  json: {\n    campaign_month: `${year}-${month}`,\n    current_date: now.toISOString()\n  }\n}];"
      },
