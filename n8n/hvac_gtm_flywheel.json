    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Parse Clay webhook payload\n// Clay sends: clay_id, email, first_name, last_name, company, domain, linkedin_url, reviews_count, service_software, score, tier, messaging_strategy\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const body = item.json.body || item.json;\n  \n  results.push({\n    json: {\n      clay_id: body.clay_id || body.id,\n      email: body.email,\n      first_name: body.first_name || body.firstName,\n      last_name: body.last_name || body.lastName,\n      company: body.company || body.company_name,\n      domain: body.domain,\n      linkedin_url: body.linkedin_url || body.linkedinUrl,\n      reviews_count: parseInt(body.reviews_count || body.reviewsCount || 0),\n      service_software: body.service_software || body.serviceSoftware || null,\n      score: parseInt(body.score || 0),\n      tier: body.tier,\n      messaging_strategy: body.messaging_strategy || body.messagingStrategy,\n      score_breakdown: body.score_breakdown || body.scoreBreakdown || {},\n      clay_raw_data: body\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "parse-clay-payload",
      "name": "Parse Clay Webhook Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/rpc/sync_lead_from_clay",
