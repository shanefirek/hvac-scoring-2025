    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Parse Smartlead engagement event\n// Expected payload: event_type, lead_email, campaign_id, sequence_number, subject, stats_id, etc.\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const body = item.json.body || item.json;\n  \n  results.push({\n    json: {\n      email: body.lead_email || body.email,\n      campaign_id: parseInt(body.campaign_id || body.campaignId),\n      event_type: body.event_type || body.eventType,\n      sequence_number: parseInt(body.sequence_number || body.sequenceNumber || 0),\n      email_subject: body.subject || body.email_subject,\n      email_stats_id: body.stats_id || body.email_stats_id,\n      event_data: body\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "parse-smartlead-event",
      "name": "Parse Smartlead Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 700]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/rpc/record_smartlead_event",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
