    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/rpc/get_leads_for_campaign",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"p_tier\": $(\"Loop Through Campaigns\").item.json.tier,\n  \"p_campaign_month\": $(\"Get Current Month\").item.json.campaign_month,\n  \"p_daily_limit\": $(\"Loop Through Campaigns\").item.json.daily_send_limit\n} }}",
        "options": {}
      },
      "id": "get-leads-for-campaign",
      "name": "Get Leads Ready for Campaign",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 1100]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Format leads for Smartlead API\nconst campaign = $(\"Loop Through Campaigns\").item.json;\nconst leads = $input.all();\n\nconst formattedLeads = leads.map(item => ({\n  email: item.json.email,\n  first_name: item.json.first_name,\n  last_name: item.json.last_name,\n  company_name: item.json.company,\n  custom_fields: {\n    score: item.json.score,\n    tier: campaign.tier\n  }\n}));\n\nreturn [{\n  json: {\n    campaign_id: campaign.smartlead_campaign_id,\n    campaign_name: campaign.name,\n    tier: campaign.tier,\n    leads: formattedLeads,\n    lead_count: formattedLeads.length\n  }\n}];"
      },
      "id": "format-leads-for-smartlead",
      "name": "Format Leads for Smartlead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 1100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://server.smartlead.ai/api/v1/campaigns/{{ $json.campaign_id }}/leads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $env.SMARTLEAD_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"leads\": $json.leads } }}",
        "options": {}
      },
      "id": "add-leads-to-smartlead",
      "name": "Add Leads to Smartlead Campaign",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 1100]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Fetch lead IDs from Supabase for the emails we just added\nconst campaign = $(\"Format Leads for Smartlead\").item.json;\nconst emails = campaign.leads.map(l => l.email);\n\n// Make request to get lead IDs\nconst response = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `${$env.SUPABASE_URL}/rest/v1/leads?email=in.(${emails.join(',')})&select=id,email`,\n  headers: {\n    'apikey': $env.SUPABASE_SERVICE_KEY,\n    'Authorization': `Bearer ${$env.SUPABASE_SERVICE_KEY}`\n  }\n});\n\nconst leadMap = {};\nresponse.forEach(lead => {\n  leadMap[lead.email] = lead.id;\n});\n\n// Prepare campaign tracking records\nconst trackingRecords = emails.map(email => ({\n  lead_id: leadMap[email],\n  smartlead_campaign_id: campaign.campaign_id,\n  campaign_name: campaign.campaign_name,\n  campaign_month: $(\"Get Current Month\").item.json.campaign_month,\n  tier: campaign.tier,\n  status: 'PENDING'\n})).filter(r => r.lead_id); // Only include records where we found a lead_id\n\nreturn [{ json: { records: trackingRecords, count: trackingRecords.length } }];"
      },
      "id": "prepare-campaign-tracking",
      "name": "Prepare Campaign Tracking Records",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 1100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/campaign_tracking",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "resolution=ignore-duplicates"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.records }}",
        "options": {}
      },
      "id": "insert-campaign-tracking",
      "name": "Insert Campaign Tracking Records",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1850, 1100]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Update leads table with Smartlead tracking fields\nconst trackingData = $(\"Prepare Campaign Tracking Records\").item.json;\nconst records = trackingData.records || [];\n\nif (records.length === 0) {\n  return [{ json: { message: 'No leads to update', updated: 0 } }];\n}\n\n// Extract unique lead_ids and campaign_id\nconst leadIds = records.map(r => r.lead_id).filter(id => id);\nconst campaignId = records[0]?.smartlead_campaign_id;\n\nif (leadIds.length === 0 || !campaignId) {\n  return [{ json: { message: 'Missing lead IDs or campaign ID', updated: 0 } }];\n}\n\n// Update each lead's tracking fields\nfor (const leadId of leadIds) {\n  await this.helpers.httpRequest({\n    method: 'PATCH',\n    url: `${$env.SUPABASE_URL}/rest/v1/leads?id=eq.${leadId}`,\n    headers: {\n      'apikey': $env.SUPABASE_SERVICE_KEY,\n      'Authorization': `Bearer ${$env.SUPABASE_SERVICE_KEY}`,\n      'Content-Type': 'application/json',\n      'Prefer': 'return=minimal'\n    },\n    body: {\n      in_smartlead: true,\n      smartlead_campaign_ids: `{${campaignId}}`, // PostgreSQL array literal\n      last_smartlead_sync: new Date().toISOString()\n    }\n  });\n}\n\nreturn [{ json: { message: 'Leads updated with tracking fields', updated: leadIds.length, campaign_id: campaignId } }];"
      },
      "id": "update-lead-tracking",
      "name": "Update Lead Tracking Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 1100]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Prepare data for monthly campaign creation\nconst now = new Date();\nconst year = now.getFullYear();\nconst month = String(now.getMonth() + 1).padStart(2, '0');\nconst monthName = now.toLocaleString('default', { month: 'short' });\n\nconst tiers = ['A', 'B', 'C'];\nconst campaigns = tiers.map(tier => ({\n  tier: tier,\n  campaign_month: `${year}-${month}`,\n  campaign_name: `${monthName} ${year} ${tier}-Tier HVAC`,\n  daily_send_limit: tier === 'B' ? 25 : 30\n}));\n\nreturn campaigns.map(c => ({ json: c }));"
      },
      "id": "prepare-monthly-campaigns",
      "name": "Prepare Monthly Campaign Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 1500]
    }
