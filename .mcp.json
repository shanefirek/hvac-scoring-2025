{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      },
      "enabled": true
    },
    "smartlead": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.smartlead.ai/sse?user_api_key=38ee964e-b100-4e2b-bfc1-a6ebf5ef48d3_4l5qyv8"
      ],
      "enabled": true
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=rlmuovkdvbxzyylbiunj"
    },
    "trigger": {
      "command": "npx",
      "args": [
        "trigger.dev@latest",
        "mcp",
        "--dev-only"
      ]
    }
  }
}